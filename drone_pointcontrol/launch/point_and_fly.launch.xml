<launch>

    <arg name="fullview" default="True" description="Whether to use the full visualization"/>
    <arg name="cycleviz" default="False" description="Whether to cycle the yolodraw visualization state"/>
    <arg name="use_drone" default="False" description="Sets whether to issue control singals to the drone"/>
    <arg name="manual_acquire" default="True" description="If true, wait on manual call to calibration service"/>
    <arg name="cmd_src" default="hand" description="Command source: 'hand' for hand_landmarker, 'pong' for drone_target_broadcaster"/>

    <include file="$(find-pkg-share realsense2_camera)/launch/rs_launch.py">
        <arg name="ros_args" value="--ros-args --log-level WARN"/>
        <arg name="align_depth.enable" value="true"/>

        <arg name="rgb_camera.color_profile" value="1280x720x30"/>
        <arg name="depth_module.depth_profile" value="1280x720x30"/>
    </include>

    <node pkg="drone_pointcontrol" exec="yolotracking" on_exit='shutdown'>
        <param name="model_path" value="$(find-pkg-share drone_pointcontrol)/models/tello-track-2.pt"/>
    </node>

    <node pkg="drone_pointcontrol" exec="visiontracking" on_exit='shutdown'>
        <param name="mask_path" value="$(find-pkg-share drone_pointcontrol)/masks/dronemask.png"/>
        <param name="server_url" value="http://lamb.mech.northwestern.edu:4242"/>

        <remap from="/camera/camera/aligned_depth_to_color/image_raw" to="/cropped/aligned_depth_to_color/image_raw"/>
        <remap from="/camera/camera/color/image_raw" to="/cropped/color/image_raw"/>
        <remap from="/camera/camera/color/camera_info" to="/cropped/camera_info"/>
    </node>

    <node pkg="drone_pointcontrol" exec="positioncontrol" on_exit='shutdown'>
        <param name="drone_frame" value="drone_pose"/>
        <param name="target_frame" value="drone_target"/>
        <param name="use_drone" value="$(var use_drone)"/>
        <param name="manual_acquire" value="$(var manual_acquire)"/>
    </node>

    <node pkg="drone_pointcontrol" exec="yolodraw">
        <param name="model_path" value="$(find-pkg-share drone_pointcontrol)/models/tello-track-2.pt"/>
        <param name="increment_visualizations" value="$(var cycleviz)"/>
        <remap from="/camera/camera/color/image_raw" to="/hand_landmarker/annotated_image"/>
        <remap from="/camera/camera/color/camera_info" to="/hand_landmarker/camera_info"/>
    </node>

    <!-- <node
        pkg="tf2_ros"
        exec="static_transform_publisher"
        name="static_tf_camera_offset"
        args="1.2 0 0 0 0 0 camera_link drone_target"
    /> -->
    <node pkg="drone_pointcontrol" exec="hand_landmarker" on_exit="shutdown" if="$(eval '\'$(var cmd_src)\' == \'hand\'')"/>
    <node pkg="drone_pointcontrol" exec="drone_target_broadcaster" on_exit="shutdown" if="$(eval '\'$(var cmd_src)\' == \'pong\'')"/>

    <node pkg="rviz2" exec="rviz2" args="-d $(find-pkg-share drone_pointcontrol)/config/yolocrop.rviz" on_exit='shutdown' if="$(eval '\'$(var fullview)\' == \'False\'')">
    </node>

    <node pkg="rviz2" exec="rviz2" args="-d $(find-pkg-share drone_pointcontrol)/config/overlay.rviz" on_exit="shutdown" if="$(eval '\'$(var fullview)\' == \'True\'')">
    </node>

    <node pkg="teleop_twist_keyboard" exec="teleop_twist_keyboard" name="teleop_twist_keyboard" launch-prefix="xterm -e" if="$(var use_drone)"/>

</launch>