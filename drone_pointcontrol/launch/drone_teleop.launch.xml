<launch>

    <node pkg="drone_pointcontrol" exec="positioncontrol" on_exit='shutdown'>
        <param name="drone_frame" value="drone_pose"/>
        <param name="target_frame" value="drone_target"/>
        <param name="use_drone" value="True"/>
    </node>


    <node pkg="teleop_twist_keyboard" exec="teleop_twist_keyboard" name="teleop_twist_keyboard" launch-prefix="xterm -e" on_exit="shutdown"/>

</launch>